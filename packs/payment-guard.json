    {
      "name": "Require access request for square api batch delete catalog objects",
      "description": "Square API POST /v2/catalog/batch-delete deletes multiple catalog objects.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 140,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:[^\\n]*?(?:-X\\s*|--request(?:=|\\s+))POST\\b[^\\n]*?https?://(?:api\\.squareup\\.com|connect\\.squareup(?:sandbox)?\\.com)[^\\s'\"]*/v2/catalog/batch-delete(?:[^\\s'\"]*)?|[^\\n]*?https?://(?:api\\.squareup\\.com|connect\\.squareup(?:sandbox)?\\.com)[^\\s'\"]*/v2/catalog/batch-delete(?:[^\\s'\"]*)?[^\\n]*?(?:-X\\s*|--request(?:=|\\s+))POST\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
