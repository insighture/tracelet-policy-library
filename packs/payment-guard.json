{
  "id": "payment-guard",
  "name": "Payment Providers Guard",
  "category": "payment",
  "description": "Protects payment providers: deleting customers, subscriptions, webhooks, and products, and issuing refunds across Stripe, Braintree, and Square. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for stripe customers delete",
      "description": "stripe customers delete permanently deletes a customer.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bstripe\\b(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+customers\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for braintree customer delete",
      "description": "braintree.Customer.delete permanently deletes a Braintree customer.",
      "action": "request_access",
      "fail_mode": "closed",
