      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 480,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "dmsetup\\b.*?\\s+create\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for nbd client disconnect",
      "description": "nbd-client -d disconnects a network block device. Data loss if not properly unmounted.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 490,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "nbd-client\\s+(?:.*\\s+)?-d\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for nbd client connect",
