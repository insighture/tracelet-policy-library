      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 460,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "dmsetup\\b.*?\\s+clear\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for dmsetup load",
      "description": "dmsetup load changes device mapping. Verify the new table is correct.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 470,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "dmsetup\\b.*?\\s+load\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
