      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 510,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bpvremove\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
