        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for btrfs check repair",
      "description": "btrfs check --repair is DANGEROUS and can cause data loss. Backup first!",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 400,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "btrfs\\b.*?\\s+check\\s+(?:.*\\s+)?--repair\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for btrfs rescue",
      "description": "btrfs rescue operations modify filesystem metadata. Use only as last resort.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 410,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "btrfs\\b.*?\\s+rescue\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for btrfs filesystem resize",
      "description": "btrfs filesystem resize can shrink a filesystem. Data loss if size is too small.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 420,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "btrfs\\b.*?\\s+filesystem\\s+resize\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for dmsetup remove",
      "description": "dmsetup remove detaches a device-mapper device. May cause data loss if in use.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 430,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "dmsetup\\b.*?\\s+remove\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for dmsetup remove all",
      "description": "dmsetup remove_all removes ALL device-mapper devices. Extremely dangerous!",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 440,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "dmsetup\\b.*?\\s+remove_all\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for dmsetup wipe table",
      "description": "dmsetup wipe_table replaces the device table, causing all I/O to fail.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 450,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "dmsetup\\b.*?\\s+wipe_table\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for dmsetup clear",
