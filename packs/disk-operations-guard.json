      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 500,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "nbd-client\\s+\\S+\\s+\\d+\\s+['\"]?/dev/nbd"
