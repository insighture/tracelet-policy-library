    {
      "name": "Require justification for haproxy config delete",
      "description": "Removing files from /etc/haproxy deletes HAProxy configuration.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 390,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\brm\\b.*\\s+['\"]?/etc/haproxy(?:/|\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for traefik kubectl delete ingressroute",
      "description": "Deleting IngressRoute CRDs removes Traefik routing rules.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 400,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "kubectl\\b.*?\\s+delete\\s+ingressroute\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for traefik api delete",
      "description": "DELETE operations against Traefik API can remove routing configuration.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 410,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b.*\\btraefik\\b.*\\b/api/|.*\\btraefik\\b.*\\b/api/.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
