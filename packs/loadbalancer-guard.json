        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for haproxy service stop",
      "description": "service haproxy stop stops the HAProxy service.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 340,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "service\\s+haproxy\\s+stop\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for haproxy socat disable server",
      "description": "Disabling a server via HAProxy runtime API removes it from the load balancer pool.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 350,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:echo|printf)\\s+['\"]?disable\\s+server\\b.*\\|\\s*socat\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for haproxy socat shutdown sessions",
