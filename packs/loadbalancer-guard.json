      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 360,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:echo|printf)\\s+['\"]?shutdown\\s+sessions\\b.*\\|\\s*socat\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for haproxy socat disable frontend",
