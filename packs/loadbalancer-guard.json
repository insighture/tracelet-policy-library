      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 280,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b(?:\\s+(?:--profile|--region|--output|--endpoint-url)\\s+\\S+|\\s+--\\S+)*\\s+elbv2\\s+delete-rule\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for elb delete load balancer",
      "description": "aws elb delete-load-balancer permanently deletes the classic load balancer.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 290,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b(?:\\s+(?:--profile|--region|--output|--endpoint-url)\\s+\\S+|\\s+--\\S+)*\\s+elb\\s+delete-load-balancer\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for elb deregister instances",
      "description": "aws elb deregister-instances-from-load-balancer removes instances from the load balancer, impacting live traffic.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 300,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b(?:\\s+(?:--profile|--region|--output|--endpoint-url)\\s+\\S+|\\s+--\\S+)*\\s+elb\\s+deregister-instances-from-load-balancer\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for haproxy soft stop",
      "description": "haproxy -sf sends a soft stop signal, terminating the load balancer gracefully.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 310,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bhaproxy\\s+.*-sf\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for haproxy hard stop",
      "description": "haproxy -st sends a hard stop signal, immediately terminating the load balancer.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 320,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bhaproxy\\s+.*-st\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for haproxy systemctl stop",
