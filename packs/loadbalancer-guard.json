    },
    {
      "name": "Require justification for haproxy socat shutdown frontend",
      "description": "Shutting down a frontend via HAProxy runtime API terminates it immediately.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 380,
      "rule_type": "command_filter",
      "rule_config": {
