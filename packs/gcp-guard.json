      "fail_mode": "closed",
      "severity": "critical",
      "priority": 190,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bsecrets\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for functions delete",
      "description": "gcloud functions delete removes the Cloud Function.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 200,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bfunctions\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for kms keys destroy",
      "description": "gcloud kms keys versions destroy schedules a CryptoKeyVersion for destruction — data encrypted with it becomes unrecoverable.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 200,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bkms\\s+keys\\s+versions\\s+destroy"
