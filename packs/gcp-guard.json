{
  "id": "gcp-guard",
  "name": "GCP Guard",
  "category": "gcp",
  "description": "Protects Google Cloud: project/instance deletion, GCS bucket removal, GKE cluster teardown, IAM policy changes, and destructive gcloud/gsutil operations. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for compute delete",
      "description": "gcloud compute instances delete permanently destroys VM instances.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bcompute\\s+instances\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for disk delete",
      "description": "gcloud compute disks delete permanently destroys disk data.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bcompute\\s+disks\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for sql delete",
      "description": "gcloud sql instances delete permanently destroys the Cloud SQL instance.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 120,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bsql\\s+instances\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for gsutil rm recursive",
      "description": "gsutil rm -r permanently deletes all objects in the path.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 130,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gsutil\\b.*?\\brm\\s+.*-r|gsutil\\b.*?\\brm\\s+-[a-z]*r"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for gsutil rb",
      "description": "gsutil rb removes the entire GCS bucket.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 140,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gsutil\\b.*?\\brb(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for gke delete",
      "description": "gcloud container clusters delete removes the entire GKE cluster.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 150,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bcontainer\\s+clusters\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for project delete",
      "description": "gcloud projects delete removes the entire GCP project and ALL its resources!",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 160,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bprojects\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for firestore delete",
      "description": "gcloud firestore delete removes Firestore data.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 170,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gcloud\\b.*?\\bfirestore\\s+.*delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for artifacts repositories delete",
      "description": "gcloud artifacts repositories delete permanently deletes the repository.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 180,
