{
  "id": "backup-guard",
  "name": "Backup Guard",
  "category": "backup",
  "description": "Protects backup systems — the last line of defence: snapshot forgetting/pruning, repository deletion, rclone purge/delete, and Velero backup removal. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for restic forget",
      "description": "restic forget removes snapshots and can permanently delete backup data.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "restic\\b.*\\sforget\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for restic prune",
      "description": "restic prune removes unreferenced data and is irreversible.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "restic\\b.*\\sprune\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for restic key remove",
      "description": "restic key remove deletes encryption keys and can make backups unrecoverable.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 120,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "restic\\b.*\\skey\\b.*\\sremove\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for borg delete",
      "description": "borg delete removes archives or entire repositories.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 130,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "borg(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for rclone sync",
      "description": "rclone sync deletes destination files not present in the source.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 140,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rclone(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+sync\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for rclone delete",
      "description": "rclone delete removes files and directories from the target.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 150,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rclone(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for rclone purge",
      "description": "rclone purge deletes a path and all its contents.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 160,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rclone(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+purge\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for velero uninstall",
      "description": "velero uninstall removes the Velero deployment and related resources.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 170,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "velero(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+uninstall\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for restic unlock remove all",
      "description": "restic unlock --remove-all force-removes repository locks.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 200,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "restic\\b.*\\sunlock\\b.*\\s--remove-all\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for borg prune",
      "description": "borg prune removes archives based on retention rules.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 210,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "borg(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+prune\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for borg recreate",
      "description": "borg recreate can drop data from archives.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 220,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "borg(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+recreate\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for rclone deletefile",
      "description": "rclone deletefile removes a single file from the target.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 230,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rclone(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+deletefile\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for rclone dedupe",
      "description": "rclone dedupe can delete or rename duplicate files.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 240,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rclone(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+dedupe\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for rclone move",
      "description": "rclone move deletes source files after copying.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 250,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rclone(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+move\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for velero backup delete",
      "description": "velero backup delete removes a backup and its data.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 260,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "velero(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+backup\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for velero backup location delete",
      "description": "velero backup-location delete removes a backup storage location.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 270,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "velero(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+backup-location\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for velero snapshot location delete",
      "description": "velero snapshot-location delete removes a snapshot location.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 280,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "velero(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+snapshot-location\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on borg compact",
      "description": "borg compact reclaims space after deletions.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 300,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "borg(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+compact\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on borg break lock",
      "description": "borg break-lock forces removal of repository locks.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 310,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "borg(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+break-lock\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on rclone cleanup",
      "description": "rclone cleanup removes old/malformed uploads.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 320,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rclone(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+cleanup\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on velero schedule delete",
      "description": "velero schedule delete removes scheduled backups.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 330,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "velero(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+schedule\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Log restic cache cleanup",
      "description": "restic cache --cleanup removes cached data from disk.",
      "action": "log",
      "fail_mode": "open",
      "severity": "low",
      "priority": 400,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "restic\\b.*\\scache\\b.*\\s--cleanup\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Log velero restore delete",
      "description": "velero restore delete removes restore records.",
      "action": "log",
      "fail_mode": "open",
      "severity": "low",
      "priority": 410,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "velero(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+restore\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    }
  ]
}
