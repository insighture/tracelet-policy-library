{
  "id": "secrets-managers-guard",
  "name": "Secrets Managers Guard",
  "category": "secrets",
  "description": "Protects secret-manager CLIs: HashiCorp Vault seal/revoke/delete, AWS Secrets Manager deletion, 1Password item/vault removal, and Doppler secret deletion. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for vault secrets disable",
      "description": "vault secrets disable disables a secrets engine, causing data loss.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "vault(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+secrets\\s+disable\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for vault kv destroy",
      "description": "vault kv destroy permanently deletes secret versions.",
