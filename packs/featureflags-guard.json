{
  "id": "featureflags-guard",
  "name": "Feature Flags Guard",
  "category": "featureflags",
  "description": "Protects feature-flag platforms: flag/segment deletion, environment removal, and project teardown across LaunchDarkly, Split, Flipt, and Unleash. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for ldcli flags delete",
      "description": "ldcli flags delete permanently removes a feature flag. This cannot be undone.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "ldcli(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+flags\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for ldcli projects delete",
      "description": "ldcli projects delete removes an entire project and all its flags, environments, and settings.",
