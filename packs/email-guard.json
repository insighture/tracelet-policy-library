{
  "id": "email-guard",
  "name": "Email Providers Guard",
  "category": "email",
  "description": "Protects transactional email providers: identity/domain deletion, template removal, suppression-list changes, and API-key deletion across SES, SendGrid, Mailgun, and Postmark. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for ses delete receipt rule set",
      "description": "aws ses delete-receipt-rule-set removes a receipt rule set.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+ses\\s+delete-receipt-rule-set\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
