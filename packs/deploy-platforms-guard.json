{
  "id": "deploy-platforms-guard",
  "name": "Deploy Platforms Guard",
  "category": "platform",
  "description": "Protects deployment platforms: project/service/environment deletion, volume wipes, variable removal, and app teardown across Railway, Kamal, and Modal. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for railway project delete",
      "description": "railway delete schedules deletion of the entire Railway project. Safer alternative: `railway status` — Confirm the currently linked project and environment before any project change.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:^|[^\\w-])railway\\b(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for railway project subcommand delete",
      "description": "railway project delete schedules deletion of the entire Railway project. Safer alternative: `railway status` — Confirm the currently linked project and environment before any project change.",
      "action": "request_access",
