{
  "id": "aws-extended",
  "name": "AWS Extended",
  "category": "aws",
  "description": "Extended AWS CLI protection beyond AWS Baseline: EC2/EBS/RDS deletion, S3 wipes, IAM and security-group changes, Lambda/ECS/EKS teardown, CloudFormation stack deletion, and more. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for ec2 terminate",
      "description": "aws ec2 terminate-instances permanently destroys EC2 instances.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "aws\\b.*?\\bec2\\s+terminate-instances"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for s3 rm recursive",
      "description": "aws s3 rm --recursive permanently deletes all objects in the path.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "aws\\b.*?\\bs3\\s+rm\\s+.*--recursive"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
