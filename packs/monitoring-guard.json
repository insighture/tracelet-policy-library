{
  "id": "monitoring-guard",
  "name": "Monitoring Guard",
  "category": "monitoring",
  "description": "Protects observability systems: deleting dashboards, monitors, alert rules, escalation policies, and retention data across Datadog, PagerDuty, Prometheus, New Relic, and Splunk. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for pd service delete",
      "description": "pd service delete removes a PagerDuty service, which can break incident routing.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bpd\\b(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+service\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for pagerduty api delete service",
      "description": "PagerDuty API DELETE /services/{id} deletes a PagerDuty service.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b.*api\\.pagerduty\\.com[^\\s]*?/services/[^\\s]+|.*api\\.pagerduty\\.com[^\\s]*?/services/[^\\s]+.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for prometheus rules file delete",
      "description": "Deleting Prometheus rule/config files can break alerting and monitoring coverage.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 120,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\brm\\b(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+(?:(?:-f|--force)\\s+)?['\"]?(?:/etc/prometheus/(?:rules\\.d|rules)/\\S+|/etc/prometheus/(?:prometheus|rules)\\.(?:ya?ml))['\"]?(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for prometheus tsdb delete series",
      "description": "Prometheus TSDB delete_series permanently deletes time series data.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 130,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:.*(?:-X\\s*|--request(?:=|\\s+))POST\\b.*\\/api\\/v1\\/admin\\/tsdb\\/delete_series\\b|.*\\/api\\/v1\\/admin\\/tsdb\\/delete_series\\b.*(?:-X\\s*|--request(?:=|\\s+))POST\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for splunk remove index",
      "description": "splunk remove index deletes an index and its data permanently.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 140,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "splunk\\b.*?\\bremove\\s+index\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for splunk clean eventdata",
