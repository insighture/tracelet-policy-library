{
  "id": "messaging-guard",
  "name": "Messaging Guard",
  "category": "messaging",
  "description": "Protects message brokers: topic/queue deletion, consumer-group resets, exchange removal, and stream purges across Kafka, RabbitMQ, NATS, and SQS/SNS. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for kafka topics delete",
      "description": "kafka-topics --delete removes Kafka topics and data.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "kafka-topics(?:\\.sh)?\\b.*\\s--delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for kafka delete records",
      "description": "kafka-delete-records deletes records up to specified offsets.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "kafka-delete-records(?:\\.sh)?\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for rpk topic delete",
      "description": "rpk topic delete removes topics (Kafka-compatible).",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 120,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rpk\\b.*\\stopic\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for rabbitmqadmin delete queue",
      "description": "rabbitmqadmin delete queue permanently deletes a queue.",
