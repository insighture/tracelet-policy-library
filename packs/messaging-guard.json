      "fail_mode": "closed",
      "severity": "critical",
      "priority": 130,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "rabbitmqadmin(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete\\s+queue\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
