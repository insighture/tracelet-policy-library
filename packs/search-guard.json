{
  "id": "search-guard",
  "name": "Search & Indexing Guard",
  "category": "search",
  "description": "Protects search clusters: index deletion, delete-by-query, snapshot removal, and cluster-settings changes across Elasticsearch, OpenSearch, Algolia, and Meilisearch. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for es curl delete index",
      "description": "curl -X DELETE against an Elasticsearch index (or _all/*) deletes data permanently.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b.*\\b(?:https?://)?[^\\s'\\\"]*(?:elastic|:9200)[^\\s'\\\"]*/(?:_all|\\*|[a-z0-9][a-z0-9._-]*)(?:[\\s?'\"]|$)|.*\\b(?:https?://)?[^\\s'\\\"]*(?:elastic|:9200)[^\\s'\\\"]*/(?:_all|\\*|[a-z0-9][a-z0-9._-]*)(?:[\\s?'\"]|$).*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for es http delete index",
