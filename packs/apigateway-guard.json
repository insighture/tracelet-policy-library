{
  "id": "apigateway-guard",
  "name": "API Gateway Guard",
  "category": "apigateway",
  "description": "Protects API gateways: API/stage/route deletion, consumer and plugin removal, and proxy undeployment across AWS API Gateway, Kong, and Apigee. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for apigateway delete rest api",
      "description": "aws apigateway delete-rest-api permanently removes a REST API and all its resources.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+apigateway\\s+delete-rest-api\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for apigatewayv2 delete api",
      "description": "aws apigatewayv2 delete-api permanently removes an HTTP API.",
      "action": "request_access",
      "fail_mode": "closed",
