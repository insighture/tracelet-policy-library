{
  "id": "dns-guard",
  "name": "DNS Guard",
  "category": "dns",
  "description": "Protects DNS: zone and record deletion across Cloudflare, Route 53, and generic DNS tooling. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for cloudflare api delete zone",
      "description": "curl -X DELETE against /zones/{id} deletes a Cloudflare zone.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b.*\\bapi\\.cloudflare\\.com\\b[^\\s]*?/zones/[^\\s]+|.*\\bapi\\.cloudflare\\.com\\b[^\\s]*?/zones/[^\\s]+.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for route53 delete hosted zone",
      "description": "aws route53 delete-hosted-zone permanently deletes a Route53 hosted zone.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b.*?\\broute53\\s+delete-hosted-zone\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for cloudflare wrangler dns delete",
      "description": "wrangler dns-records delete removes a Cloudflare DNS record.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 200,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "wrangler(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+dns-records\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for cloudflare api delete dns record",
      "description": "curl -X DELETE against /dns_records/{id} deletes a Cloudflare DNS record.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 210,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b.*\\bapi\\.cloudflare\\.com\\b[^\\s]*?/dns_records/[^\\s]+|.*\\bapi\\.cloudflare\\.com\\b[^\\s]*?/dns_records/[^\\s]+.*(?:-X\\s*|--request(?:=|\\s+))DELETE\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for cloudflare terraform destroy record",
      "description": "terraform destroy -target=cloudflare_record deletes specific DNS records.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 220,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "terraform\\b.*?\\s+destroy\\s+.*-target=(?:resource\\.)?cloudflare_record\\."
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for route53 change resource record sets delete",
      "description": "aws route53 change-resource-record-sets with DELETE removes DNS records.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 230,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b.*?\\broute53\\s+change-resource-record-sets\\b.*\\bDELETE\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for route53 delete health check",
      "description": "aws route53 delete-health-check permanently deletes a Route53 health check.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 240,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b.*?\\broute53\\s+delete-health-check\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for route53 delete traffic policy",
      "description": "aws route53 delete-traffic-policy permanently deletes a Route53 traffic policy.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 250,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b.*?\\broute53\\s+delete-traffic-policy\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for route53 delete reusable delegation set",
      "description": "aws route53 delete-reusable-delegation-set permanently deletes a reusable delegation set.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 260,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b.*?\\broute53\\s+delete-reusable-delegation-set\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for dns nsupdate delete",
      "description": "nsupdate delete commands remove DNS records.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 270,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:\\bnsupdate\\b.*\\bdelete\\b|\\bdelete\\b.*\\|\\s*\\bnsupdate\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on route53 delete query logging config",
      "description": "aws route53 delete-query-logging-config removes a Route53 query logging configuration.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 300,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\baws\\b.*?\\broute53\\s+delete-query-logging-config\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on dns nsupdate local",
      "description": "nsupdate -l applies local updates which can modify DNS records.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 310,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bnsupdate\\b.*\\s-l\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on dns dig zone transfer",
      "description": "dig AXFR/IXFR zone transfers can exfiltrate full zone data.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 320,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i:\\bdig\\b.*\\b(?:axfr|ixfr)\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    }
  ]
}
