{
  "id": "cicd-guard",
  "name": "CI/CD Guard",
  "category": "cicd",
  "description": "Protects CI/CD systems: deleting workflows, runners, pipelines, jobs, caches, and secrets across GitHub Actions, GitLab CI, Jenkins, and CircleCI. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for gitlab runner unregister",
      "description": "gitlab-runner unregister removes runners and can halt CI.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "gitlab-runner(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+unregister\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for jenkins cli delete job",
      "description": "jenkins-cli delete-job deletes Jenkins jobs and can break pipelines.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:jenkins-cli|java\\s+-jar\\s+\\S*jenkins-cli\\.jar)(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete-job\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for jenkins curl do delete",
      "description": "curl POST to Jenkins doDelete endpoints deletes jobs or resources.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 120,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bcurl\\b(?:.*(?:-X\\s*|--request(?:=|\\s+))POST\\b.*\\bdoDelete\\b|.*\\bdoDelete\\b.*(?:-X\\s*|--request(?:=|\\s+))POST\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for circleci context delete",
      "description": "circleci context delete removes contexts and their secrets.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 130,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "circleci(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+context\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for circleci namespace delete",
      "description": "circleci namespace delete removes an orb namespace.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 140,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "circleci(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+namespace\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for gh actions secret remove",
      "description": "gh secret delete/remove deletes GitHub Actions secrets. This can break CI and may be hard to recover.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 200,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bgh\\b[^|;&]*?\\s+secret\\s+(?:delete|remove)\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for gh actions api delete secrets",
      "description": "gh api DELETE against /actions/secrets deletes GitHub Actions secrets.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 210,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bgh\\b[^|;&]*?\\s+api\\b.*(?:-X\\s*|--method(?:=|\\s+))DELETE\\b.*\\b/?repos/[^\\s/]+/[^\\s/]+/actions/secrets\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for glab variable delete",
      "description": "glab variable delete removes CI variables and can break pipelines.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 220,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "glab(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+variable\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for glab api delete variables",
      "description": "glab api DELETE against variables endpoints removes CI variables.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 230,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "glab(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+api\\b.*(?:-X\\s*|--method(?:=|\\s+))DELETE\\b.*\\bvariables\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for jenkins cli delete node",
      "description": "jenkins-cli delete-node deletes Jenkins nodes and can halt CI.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 240,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:jenkins-cli|java\\s+-jar\\s+\\S*jenkins-cli\\.jar)(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete-node\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for jenkins cli delete credentials",
      "description": "jenkins-cli delete-credentials removes stored credentials.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 250,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:jenkins-cli|java\\s+-jar\\s+\\S*jenkins-cli\\.jar)(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete-credentials\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for circleci context remove secret",
      "description": "circleci context remove-secret deletes secrets from a context.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 260,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "circleci(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+context\\s+remove-secret\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for circleci orb delete",
      "description": "circleci orb delete removes an orb from the registry.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 270,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "circleci(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+orb\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for circleci api delete envvar",
      "description": "curl DELETE against CircleCI envvar endpoints removes environment variables.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 280,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "curl(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+(?:-X\\s*|--request(?:=|\\s+))DELETE\\b.*circleci\\.com/api/[^\\s]*\\b(?:envvar|environment-variable)\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on gh actions variable remove",
      "description": "gh variable delete/remove deletes GitHub Actions variables. This can break workflows.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 300,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bgh\\b[^|;&]*?\\s+variable\\s+(?:delete|remove)\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on gh actions api delete variables",
      "description": "gh api DELETE against /actions/variables deletes GitHub Actions variables.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 310,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bgh\\b[^|;&]*?\\s+api\\b.*(?:-X\\s*|--method(?:=|\\s+))DELETE\\b.*\\b/?repos/[^\\s/]+/[^\\s/]+/actions/variables\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on glab ci delete",
      "description": "glab ci delete removes pipeline artifacts or pipelines.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 320,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "glab(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+ci\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on jenkins cli delete builds",
      "description": "jenkins-cli delete-builds removes build history and artifacts.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 330,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:jenkins-cli|java\\s+-jar\\s+\\S*jenkins-cli\\.jar)(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete-builds\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on circleci pipeline delete",
      "description": "circleci pipeline delete removes pipeline history.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 340,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "circleci(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+pipeline\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Log gh actions workflow disable",
      "description": "gh workflow disable disables workflows. This is reversible, but can disrupt CI.",
      "action": "log",
      "fail_mode": "open",
      "severity": "low",
      "priority": 400,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bgh\\b[^|;&]*?\\s+workflow\\s+disable\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Log gh actions run cancel",
      "description": "gh run cancel cancels a running workflow. This is reversible, but may disrupt deployments.",
      "action": "log",
      "fail_mode": "open",
      "severity": "low",
      "priority": 410,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "\\bgh\\b[^|;&]*?\\s+run\\s+cancel\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Log jenkins cli delete view",
      "description": "jenkins-cli delete-view removes Jenkins views.",
      "action": "log",
      "fail_mode": "open",
      "severity": "low",
      "priority": 420,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?:jenkins-cli|java\\s+-jar\\s+\\S*jenkins-cli\\.jar)(?:\\s+--?\\S+(?:\\s+\\S+)?)*\\s+delete-view\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    }
  ]
}
