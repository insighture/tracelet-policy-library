{
  "id": "iac-guard",
  "name": "IaC Tools Guard",
  "category": "infrastructure",
  "description": "Protects infrastructure-as-code tools beyond Terraform: pulumi destroy and stack removal, destructive ansible runs, and atmos terraform wrappers. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for destroy",
      "description": "pulumi destroy removes ALL managed infrastructure. Use 'pulumi preview --diff' first.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "pulumi\\b.*?\\bdestroy(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for shell rm rf",
      "description": "Ansible shell/command with 'rm -rf' is destructive. Review carefully.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "ansible\\s+.*-m\\s+(?:shell|command)\\s+.*rm\\s+-rf"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for atmos destroy",
      "description": "atmos terraform destroy removes ALL managed infrastructure for the component/stack.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 120,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sdestroy(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for atmos helmfile destroy",
      "description": "atmos helmfile destroy removes Helm releases from the cluster.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 130,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:helmfile|hf)\\b.*?\\sdestroy(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for up yes",
      "description": "pulumi up -y skips confirmation. Remove -y flag for safety.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 200,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "pulumi\\b.*?\\bup\\s+.*(?:-y\\b|--yes\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for state delete",
      "description": "pulumi state delete removes resource from state without destroying it.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 210,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "pulumi\\b.*?\\bstate\\s+delete"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for stack rm",
      "description": "pulumi stack rm removes the stack. Use --force only if stack is empty.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 220,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "pulumi\\b.*?\\bstack\\s+rm"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for cancel",
      "description": "pulumi cancel terminates an in-progress update, which may leave resources in inconsistent state.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 230,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "pulumi\\b.*?\\bcancel\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for shell reboot",
      "description": "Ansible shell/command with reboot/shutdown affects system availability.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 240,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "ansible\\s+.*-m\\s+(?:shell|command)\\s+.*(?:reboot|shutdown|poweroff)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for playbook all hosts",
      "description": "ansible-playbook without --check or --limit may affect all hosts. Use --check first.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 250,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "ansible-playbook\\s+.*-i\\s+\\S+\\s+\\S+\\.ya?ml"
        ],
        "allowed_patterns": [
          "ansible-playbook\\b[^|;&]*(?:--check\\b|--limit\\b)[^;&]*$"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for atmos deploy",
      "description": "atmos terraform deploy runs apply with -auto-approve (no confirmation). Preview with 'atmos terraform plan' first.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 260,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sdeploy(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for atmos apply auto approve",
      "description": "atmos terraform apply -auto-approve skips confirmation. Remove -auto-approve for safety.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 270,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sapply\\s+.*-auto-approve"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for atmos clean",
      "description": "atmos terraform clean deletes local Terraform state and generated files (.terraform/, varfiles, backend config; --everything also removes terraform.tfstate*).",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 280,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sclean(?:\\s|$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for atmos taint",
      "description": "atmos terraform taint marks a resource to be destroyed and recreated on next apply.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 290,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\staint\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on refresh yes",
      "description": "pulumi refresh -y auto-approves state changes. Review changes first.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 300,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "pulumi\\b.*?\\brefresh\\s+.*(?:-y\\b|--yes\\b)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for atmos state rm",
      "description": "atmos terraform state rm removes a resource from state without destroying it. Resource becomes unmanaged.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 300,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sstate\\s+rm\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on extra vars delete",
      "description": "Ansible extra-vars contains potentially destructive keywords. Review carefully.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 310,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "ansible\\s+.*-e\\s+['\\\"].*(?:delete|remove|destroy|drop)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for atmos state mv",
      "description": "atmos terraform state mv moves resources in state. Incorrect moves can cause resource recreation.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 310,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sstate\\s+mv\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on atmos plan destroy",
      "description": "atmos terraform plan -destroy previews destruction. Review carefully before deploying.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 320,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\splan\\s+.*-destroy"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require justification for atmos force unlock",
      "description": "atmos terraform force-unlock removes a state lock. Only use if the lock is stale.",
      "action": "justify",
      "fail_mode": "closed",
      "severity": "high",
      "priority": 320,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sforce-unlock\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Warn on atmos workspace delete",
      "description": "atmos terraform workspace delete removes a workspace and its state.",
      "action": "warn",
      "fail_mode": "open",
      "severity": "medium",
      "priority": 330,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "atmos\\b.*?\\b(?:terraform|tofu|opentofu|tf)\\b.*?\\sworkspace\\s+delete\\b"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    }
  ]
}
