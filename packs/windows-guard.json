{
  "id": "windows-guard",
  "name": "Windows Guard",
  "category": "filesystem",
  "description": "Windows-specific protection: del /s, rd /s, Remove-Item -Recurse -Force, format, diskpart, vssadmin delete shadows, registry deletion, and destructive PowerShell one-liners. Derived from the destructive_command_guard pattern library.",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Require access request for del recursive",
      "description": "del /s recursively deletes every matching file in a directory tree. Safer alternative: `del /s /q <dir> /p` — Add /p to confirm each file, or scope the path precisely before deleting.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 100,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\b(?:del|erase)(?:\\.exe)?\\s+(?:[^|&\\r\\n]*\\s+)?/s\\b"
        ],
        "allowed_patterns": [
          "(?:(?i)^\\s*(?:remove-item|ri|rm|rd|rmdir|del|erase|clear-content|clc|clear-recyclebin)\\b[^|&;\\r\\n]*\\s-whatif\\b[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|erase|rd|rmdir|remove-item|ri|rm)\\b[^|&;\\r\\n]*(?:%temp%|%tmp%|\\$env:te?mp\\b|\\$env:localappdata\\\\+temp\\b|\\\\appdata\\\\+local\\\\+temp\\\\|\\\\windows\\\\+temp\\\\|\\[system\\.io\\.path\\]::gettemppath)[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|rd|rmdir|format|erase)(?:\\.exe)?\\s+/\\?\\s*$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for rd recursive",
      "description": "rd /s deletes a directory and its entire contents. Safer alternative: `del /s /q <dir> /p` — Add /p to confirm each file, or scope the path precisely before deleting.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 110,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\b(?:rd|rmdir)(?:\\.exe)?\\s+(?:[^|&\\r\\n]*\\s+)?/s\\b"
        ],
        "allowed_patterns": [
          "(?:(?i)^\\s*(?:remove-item|ri|rm|rd|rmdir|del|erase|clear-content|clc|clear-recyclebin)\\b[^|&;\\r\\n]*\\s-whatif\\b[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|erase|rd|rmdir|remove-item|ri|rm)\\b[^|&;\\r\\n]*(?:%temp%|%tmp%|\\$env:te?mp\\b|\\$env:localappdata\\\\+temp\\b|\\\\appdata\\\\+local\\\\+temp\\\\|\\\\windows\\\\+temp\\\\|\\[system\\.io\\.path\\]::gettemppath)[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|rd|rmdir|format|erase)(?:\\.exe)?\\s+/\\?\\s*$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for remove item recurse force",
      "description": "Remove-Item -Recurse -Force deletes a tree with no Recycle Bin and no prompt. Safer alternative: `Remove-Item -Recurse -Force <path> -WhatIf` — Re-run with -WhatIf first to preview exactly what would be deleted.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 120,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\b(?:remove-item|rmdir|rd|ri|rm|del|erase)\\b(?:[^|&\\r\\n]*\\s(?:-recurse|-r)\\b[^|&\\r\\n]*\\s(?:-force|-f)\\b|[^|&\\r\\n]*\\s(?:-force|-f)\\b[^|&\\r\\n]*\\s(?:-recurse|-r)\\b)"
        ],
        "allowed_patterns": [
          "(?:(?i)^\\s*(?:remove-item|ri|rm|rd|rmdir|del|erase|clear-content|clc|clear-recyclebin)\\b[^|&;\\r\\n]*\\s-whatif\\b[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|erase|rd|rmdir|remove-item|ri|rm)\\b[^|&;\\r\\n]*(?:%temp%|%tmp%|\\$env:te?mp\\b|\\$env:localappdata\\\\+temp\\b|\\\\appdata\\\\+local\\\\+temp\\\\|\\\\windows\\\\+temp\\\\|\\[system\\.io\\.path\\]::gettemppath)[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|rd|rmdir|format|erase)(?:\\.exe)?\\s+/\\?\\s*$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for format drive",
      "description": "format <drive>: erases an entire volume.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 130,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bformat(?:\\.com|\\.exe)?\\s+(?:/\\S+\\s+)*[a-z]:(?:\\s|\\\\|/|$)"
        ],
        "allowed_patterns": [
          "(?:(?i)^\\s*(?:remove-item|ri|rm|rd|rmdir|del|erase|clear-content|clc|clear-recyclebin)\\b[^|&;\\r\\n]*\\s-whatif\\b[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|erase|rd|rmdir|remove-item|ri|rm)\\b[^|&;\\r\\n]*(?:%temp%|%tmp%|\\$env:te?mp\\b|\\$env:localappdata\\\\+temp\\b|\\\\appdata\\\\+local\\\\+temp\\\\|\\\\windows\\\\+temp\\\\|\\[system\\.io\\.path\\]::gettemppath)[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:del|rd|rmdir|format|erase)(?:\\.exe)?\\s+/\\?\\s*$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
    {
      "name": "Require access request for vssadmin delete shadows",
      "description": "vssadmin delete shadows destroys Volume Shadow Copies (System Restore + backups). Safer alternative: `vssadmin list shadows` — List shadow copies (read-only) instead of deleting them.",
      "action": "request_access",
      "fail_mode": "closed",
      "severity": "critical",
      "priority": 140,
      "rule_type": "command_filter",
      "rule_config": {
        "blocked_patterns": [
          "(?i)\\bvssadmin(?:\\.exe)?\\s+(?:[^|&\\r\\n]*\\s+)?delete\\s+shadows\\b"
        ],
        "allowed_patterns": [
          "(?:(?i)^\\s*vssadmin(?:\\.exe)?\\s+list\\b[^|&;\\r\\n]*$)|(?:(?i)^\\s*diskpart(?:\\.exe)?\\s+(?:/s\\s+\\S+\\s+)?list\\b[^|&;\\r\\n]*$)|(?:(?i)^\\s*(?:format-volume|clear-disk|remove-partition|initialize-disk|reset-physicaldisk)\\b[^|&;\\r\\n]*\\s-whatif\\b[^|&;\\r\\n]*$)"
        ]
      },
      "events": [
        "pre_tool_use"
      ],
      "tools": [
        "Bash"
      ]
    },
